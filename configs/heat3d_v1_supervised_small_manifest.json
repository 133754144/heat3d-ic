{
  "dataset_name": "v1_multilayer_bc_eq_supervised_small",
  "manifest_version": "smoke_plan_v0",
  "scaffold_base_commit": "1e00a15",
  "description": "Small supervised smoke dataset manifest for Heat3D v1 train/valid development.",
  "non_claims": [
    "not_a_formal_benchmark",
    "not_model_performance_evidence",
    "not_ood_generalization_evidence",
    "not_high_fidelity_solver_dataset",
    "not_industrial_3dic_simulator_dataset"
  ],
  "default_route": {
    "external_task": "coords + condition_features -> target_temperature",
    "condition_feature_view": "relative_bc",
    "bridge": "zero_delta_u_bridge",
    "target": "DeltaT = T - T_ref",
    "recovery": "T_pred = T_ref + DeltaT_pred",
    "loss": "normalized_DeltaT_MSE"
  },
  "generation_policy": {
    "generated_data_committed_to_git": false,
    "output_under_ignored_data_dir": true,
    "generator_must_be_manifest_driven": true,
    "deterministic_seeds_required": true,
    "smoke_only_reference_solver": true
  },
  "reference_solver_scope": {
    "supported": [
      "regular_layered_rectangular_stacks_only",
      "top_Robin",
      "bottom_Dirichlet",
      "side_adiabatic",
      "perfect_contact",
      "k_field_(N,1)",
      "k_field_(N,3)"
    ],
    "unsupported": [
      "k_field_(N,6)",
      "irregular_geometry",
      "explicit_TSV_BEOL_bump_microstructure",
      "contact_resistance",
      "transient_simulation",
      "high_fidelity_solver_claims",
      "industrial_solver_claims"
    ],
    "role": "minimal reference steady solver for smoke label generation only"
  },
  "parameter_categories": [
    "literature_backed",
    "provisional_engineering_assumption",
    "requires_user_confirmation"
  ],
  "parameter_maps": {
    "bc_baseline": {
      "baseline_300K": {
        "bottom_fixed_temperature_K": 300.0,
        "top_ambient_temperature_K": 300.0,
        "status": "provisional_engineering_assumption",
        "role": "baseline diagnostic category"
      },
      "shifted_350K": {
        "bottom_fixed_temperature_K": 350.0,
        "top_ambient_temperature_K": 350.0,
        "status": "provisional_engineering_assumption",
        "role": "baseline-shift diagnostic category"
      }
    },
    "q_scale_category": {
      "low": {
        "relative_to_current_smoke_nominal": "below_nominal",
        "volumetric_heat_generation_W_m3": null,
        "status": "requires_user_confirmation"
      },
      "nominal": {
        "relative_to_current_smoke_nominal": "current_nominal",
        "volumetric_heat_generation_W_m3": null,
        "status": "requires_user_confirmation"
      },
      "high": {
        "relative_to_current_smoke_nominal": "above_nominal",
        "volumetric_heat_generation_W_m3": null,
        "status": "requires_user_confirmation"
      }
    },
    "top_h_category": {
      "low": {
        "relative_to_current_smoke_nominal": "below_nominal",
        "h_W_m2K": null,
        "status": "requires_user_confirmation"
      },
      "nominal": {
        "relative_to_current_smoke_nominal": "current_nominal",
        "h_W_m2K": null,
        "status": "requires_user_confirmation"
      },
      "high": {
        "relative_to_current_smoke_nominal": "above_nominal",
        "h_W_m2K": null,
        "status": "requires_user_confirmation"
      },
      "held_out_top_h": {
        "relative_to_current_smoke_nominal": "held_out_range",
        "h_W_m2K": null,
        "status": "requires_user_confirmation",
        "role": "test_ood_bc smoke candidate only"
      }
    },
    "k_field_mode": {
      "isotropic_equivalent": {
        "k_field_shape": "(N,1)",
        "status": "provisional_engineering_assumption"
      },
      "blockwise_equivalent": {
        "k_field_shape": "(N,1)",
        "status": "provisional_engineering_assumption"
      },
      "diagonal_anisotropic_diagnostic": {
        "k_field_shape": "(N,3)",
        "component_order": [
          "k_x",
          "k_y",
          "k_z"
        ],
        "status": "provisional_engineering_assumption"
      }
    },
    "stack_template": {
      "baseline_4_layer": {
        "role": "main same-family smoke stack",
        "status": "provisional_engineering_assumption"
      },
      "compact_3_layer": {
        "role": "simplified 3-layer smoke stack",
        "status": "provisional_engineering_assumption"
      },
      "dual_active_4_layer": {
        "role": "multi-active-layer smoke stack",
        "status": "provisional_engineering_assumption"
      },
      "interposer_like_4_layer": {
        "role": "train-side interposer-like equivalent stack variation",
        "status": "provisional_engineering_assumption"
      },
      "heldout_interposer_4_layer": {
        "role": "held-out stack smoke candidate",
        "status": "requires_user_confirmation"
      }
    },
    "resolution": {
      "first_small_supervised_smoke": {
        "policy": "keep_current_coarse_rectilinear_resolution",
        "status": "provisional_engineering_assumption",
        "notes": "No resolution variation in the first 16-sample plan."
      }
    },
    "excluded_first_step_features": [
      "irregular_footprint",
      "explicit_TSV_BEOL_bump_microstructure",
      "transient_simulation",
      "k_field_(N,6)",
      "resolution_variation"
    ]
  },
