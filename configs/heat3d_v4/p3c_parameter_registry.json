{
  "schema_version": "heat3d_v4_p3c_parameter_registry_v2",
  "scope": "design_registry_only_no_data_generated",
  "branch": "research/v4-dataset-p3c",
  "task": "coords+k(x)+q(x)+BC->T(x)",
  "generation_policy": {
    "distribution": "unified_random_generation_distribution",
    "splits": [
      "train",
      "test"
    ],
    "random_split_seed": 4301,
    "stress_split": "disabled",
    "final_probe_role": "reference_diagnostic_only_not_pass_fail",
    "production_contact_model": "R_contact=0_perfect_contact",
    "finite_contact_resistance": "implemented_deferred_not_v4_dataset_default",
    "route": [
      "P3c-0 design spec",
      "P3c-1 parameter registry",
      "P3c-2 generator skeleton",
      "P3c-3 16-sample smoke + audit",
      "P3c-4 64-sample pilot + split audit",
      "P3c-5 P3b-lite validation subset selection",
      "P3c-7 1024 production candidate",
      "P3c-8 closeout + handoff to training"
    ]
  },
  "q_source_policy": {
    "name": "semantic_boundary_inset_5pct_solver_safe_deposition",
    "semantic_domain_xyz": [
      16.0,
      16.0,
      4.0
    ],
    "semantic_boundary_inset_fraction": 0.05,
    "semantic_inset_domain_xyz": {
      "x": [
        0.8,
        15.2
      ],
      "y": [
        0.8,
        15.2
      ],
      "z": [
        0.2,
        3.8
      ]
    },
    "solver_safe_deposition_mask": "exclude_bottom_top_side_boundary_nodes",
    "forbidden_boundary_layers": [
      "bottom_dirichlet",
      "top_robin",
      "side_adiabatic"
    ],
    "required_audit_fields": [
      "q_total_target_power_W",
      "q_integral_from_array_W",
      "q_total_power_error_W",
      "q_power_on_bottom_W",
      "q_power_on_top_W",
      "q_power_on_xmin_W",
      "q_power_on_xmax_W",
      "q_power_on_ymin_W",
      "q_power_on_ymax_W",
      "q_power_on_side_W",
      "q_power_on_boundary_W",
      "q_power_on_bottom_fraction",
      "q_power_on_top_fraction",
      "q_power_on_side_fraction",
      "q_source_boundary_violation_count",
      "q_source_side_boundary_violation_count",
      "q_active_z_min",
      "q_active_z_max",
      "semantic_boundary_inset_fraction",
      "semantic_inset_domain_xyz",
      "solver_safe_deposition_mask",
      "q_deposited_on_boundary_node_count"
    ],
    "source_ref": [
      "SRC-BSPDN-2025",
      "SRC-SAUFNO-2025"
    ],
    "source_type": "generator_contract",
    "rationale": "P3c q sources are semantic interior heat-generation regions; continuous bboxes stay inside a 5% all-boundary inset and q is deposited only on solver-safe non-boundary nodes.",
    "metadata_tag": "policy=q_source_semantic_boundary_inset_solver_safe_deposition"
  },
