    "not_generator_ready"
  ],
  "default_route": {
    "external_task": "coords + condition_features -> target_temperature",
    "condition_feature_view": "relative_bc",
    "bridge": "zero_delta_u_bridge",
    "target": "DeltaT = T - T_ref",
    "recovery": "T_pred = T_ref + DeltaT_pred",
    "loss": "normalized_DeltaT_MSE"
  },
  "generation_policy": {
    "region_first": true,
    "rectilinear_grid_sampling": true,
    "source_assignment": "volume_fraction",
    "center_in_box_role": "diagnostic_baseline_only",
    "q_policy": "fixed_density",
    "generated_data_committed_to_git": false,
    "output_under_ignored_data_dir": true,
    "reference_solver": "heat3d_v1_reference_solver_v2",
    "requires_source_power_consistency_check": true,
    "requires_label_meta": true,
    "requires_label_diagnostics": true
  },
